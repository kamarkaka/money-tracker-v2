generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String        @unique @db.VarChar(255)
  passwordHash         String?       @map("password_hash") @db.VarChar(255)
  name                 String?       @db.VarChar(100)
  image                String?       @db.VarChar(500)
  authProvider         String        @default("credentials") @map("auth_provider") @db.VarChar(50)
  googleId             String?       @unique @map("google_id") @db.VarChar(255)
  sophtronCustomerId   String?       @map("sophtron_customer_id") @db.Uuid
  hasCompletedTutorial Boolean       @default(false) @map("has_completed_tutorial")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  institutions Institution[]
  accounts     Account[]
  categories   Category[]
  budgets      Budget[]
  transactions Transaction[]
  setting      UserSetting?

  @@map("user")
}

model UserSetting {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @unique @map("user_id") @db.Uuid
  theme     String @default("system") @db.VarChar(20)
  language  String @default("en") @map("language") @db.VarChar(10)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_setting")
}

model Institution {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  sophtronMemberId      String?  @map("sophtron_member_id") @db.Uuid
  name                  String   @db.VarChar(255)
  isManual              Boolean  @default(false) @map("is_manual")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User      @relation(fields: [userId], references: [id])
  accounts Account[]

  @@index([userId])
  @@unique([userId, sophtronMemberId])
  @@map("institution")
}

model Account {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId     String   @map("institution_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  sophtronAccountId String?  @map("sophtron_account_id") @db.Uuid
  sophtronMemberId  String?  @map("sophtron_member_id") @db.Uuid
  name              String   @db.VarChar(255)
  type              String   @db.VarChar(50)
  subtype           String?  @db.VarChar(50)
  balance           Decimal  @default(0) @db.Decimal(14, 2)
  currency          String   @default("USD") @db.VarChar(3)
  isHidden          Boolean  @default(false) @map("is_hidden")
  isManual          Boolean  @default(false) @map("is_manual")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  institution  Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([institutionId])
  @@index([userId])
  @@unique([userId, sophtronAccountId])
  @@map("account")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user           User              @relation(fields: [userId], references: [id])
  parent         Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[]        @relation("CategoryHierarchy")
  transactions   Transaction[]
  budgetCategory BudgetCategory?

  @@index([userId])
  @@index([parentId])
  @@map("category")
}

model Budget {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  amount    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user       User             @relation(fields: [userId], references: [id])
  categories BudgetCategory[]

  @@index([userId])
  @@map("budget")
}

model BudgetCategory {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetBucketId String @map("budget_bucket_id") @db.Uuid
  categoryId     String @unique @map("category_id") @db.Uuid

  budget   Budget   @relation(fields: [budgetBucketId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([budgetBucketId])
  @@map("budget_category")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([email])
  @@map("password_reset_token")
}

model Transaction {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  accountId             String   @map("account_id") @db.Uuid
  categoryId            String?  @map("category_id") @db.Uuid
  sophtronTransactionId String?  @map("sophtron_transaction_id") @db.VarChar(255)
  description           String   @db.VarChar(500)
  amount                Decimal  @db.Decimal(14, 2)
  date                  DateTime @db.Date
  isHidden              Boolean  @default(false) @map("is_hidden")
  isManual              Boolean  @default(false) @map("is_manual")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User      @relation(fields: [userId], references: [id])
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
  @@index([sophtronTransactionId])
  @@unique([userId, sophtronTransactionId])
  @@map("transaction")
}
